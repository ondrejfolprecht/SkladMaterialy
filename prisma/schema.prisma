generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Material {
  id                    Int        @id @default(autoincrement())
  name                  String
  category              String     @default("")
  supplier              String     @default("")
  estimatedLeadDays     Int?       @map("estimated_lead_days")
  avgActualLeadDays     Float?     @map("avg_actual_lead_days")
  estimatedMonthlyUsage Int?       @map("estimated_monthly_usage")
  currentStock          Int        @default(0) @map("current_stock")
  note                  String     @default("")
  status                String     @default("Aktivn\u00ed")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")
  orders                Order[]
  movements             Movement[]

  @@map("materials")
}

model Order {
  id             Int       @id @default(autoincrement())
  materialId     Int       @map("material_id")
  quantity       Int
  orderedAt      DateTime? @map("ordered_at")
  stockedAt      DateTime? @map("stocked_at")
  actualLeadDays Int?      @map("actual_lead_days")
  status         String    @default("V tisku")
  note           String    @default("")
  createdAt      DateTime  @default(now()) @map("created_at")
  material       Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@map("orders")
}

model Movement {
  id         Int      @id @default(autoincrement())
  materialId Int      @map("material_id")
  department String
  quantity   Int
  movedAt    DateTime @default(now()) @map("moved_at")
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@map("movements")
}
